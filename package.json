{
    "name": "soroban-audit-cli",
    "version": "0.1.0",
    "description": "Static analysis CLI for Soroban smart contracts",
    "main": "dist/cli.js",
    "bin": {
        "soroban-audit": "dist/cli.js"
    },
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "dev": "tsx src/cli.ts"
    },
    "keywords": [
        "soroban",
        "stellar",
        "audit",
        "cli",
        "static-analysis"
    ],
    "license": "MIT",
    "dependencies": {
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "tree-sitter": "^0.22.4",
        "tree-sitter-rust": "^0.24.0"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.4"
    }
}
